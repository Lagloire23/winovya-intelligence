# Copiez ce fichier en .env.local et renseignez les valeurs propres à
# l'environnement sur lequel vous travaillez (development / staging /
# production). Ne jamais committer un fichier .env réel.
#
# IMPORTANT : toute variable préfixée VITE_ est exposée au bundle client
# (visible dans le navigateur). Aucune clé sensible (service_role, clé API
# serveur, etc.) ne doit donc jamais être préfixée VITE_.

# Environnement déclaré de ce build : production | staging | development
# Sert de garde-fou (voir src/lib/env.ts) : le build refuse de démarrer si
# cette valeur est incohérente avec le projet Supabase ciblé ci-dessous.
VITE_APP_ENV=development

# Projet Supabase ciblé par ce build (anon/publishable key uniquement,
# jamais la service_role key). Remplacez par les valeurs de VOTRE projet
# (staging ou production selon l'environnement déclaré ci-dessus).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Feature flag MVP : contrôle uniquement l'affichage frontend de la couche
# "dossiers d'opportunité". Désactivé (false) par défaut partout, activé
# (true) uniquement sur staging pour test, tant que non validé en production.
VITE_FEATURE_OPPORTUNITIES_ENABLED=false

# --- Variables backend / edge functions (à titre indicatif) ---
# Ces variables ne concernent PAS ce fichier .env frontend : elles sont
# configurées séparément dans les secrets des edge functions Supabase et ne
# doivent jamais apparaître dans un fichier .env* du dépôt.
#   SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
#   ANTHROPIC_API_KEY
#   VEILLE_EXECUTION_MODE            (ex. "production" | "test")
#   OPPORTUNITY_ENGINE_ENABLED        (ex. "false" | "true" — contrôle
#                                      l'exécution backend du moteur
#                                      d'opportunités ; jamais préfixé VITE_
#                                      puisqu'il ne doit jamais être exposé
#                                      au frontend. Réservé pour le Sprint 1,
#                                      aucune edge function ne le lit encore.)
